{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "node"],
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "paths": {
      "@domain/*": ["./src/domain/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.test.ts", "**/*.spec.ts"]
}
